<Application x:Class="Tractor80.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <LinearGradientBrush x:Key="TableBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#071A16" Offset="0" />
            <GradientStop Color="#0E2B23" Offset="0.46" />
            <GradientStop Color="#06100E" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBrush" Color="#10231D" />
        <SolidColorBrush x:Key="PanelBrushSoft" Color="#17362D" />
        <SolidColorBrush x:Key="GoldBrush" Color="#D6B45F" />
        <SolidColorBrush x:Key="AmberBrush" Color="#F0C766" />
        <SolidColorBrush x:Key="TextBrush" Color="#F2F6EF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AEB8AD" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E56D68" />

        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="24"
                          Color="#000000"
                          Direction="270"
                          Opacity="0.28"
                          ShadowDepth="8" />

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          Color="#000000"
                          Direction="270"
                          Opacity="0.34"
                          ShadowDepth="5" />

        <Style x:Key="CommandButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#071813" />
            <Setter Property="Background" Value="{StaticResource GoldBrush}" />
            <Setter Property="BorderBrush" Value="#E7CA7C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource CommandButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#1A3A31" />
            <Setter Property="BorderBrush" Value="#2C5F4F" />
        </Style>

        <Style x:Key="FlatCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.45" />
        </Style>

        <Style x:Key="ModernLogItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Background" Value="#251A3A31" />
            <Setter Property="BorderBrush" Value="#163D32" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernLogListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#4410221D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernLogItemStyle}" />
        </Style>
    </Application.Resources>
</Application>
