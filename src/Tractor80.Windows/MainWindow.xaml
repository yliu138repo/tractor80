<Window x:Class="Tractor80.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tractor 80"
        Width="1360"
        Height="900"
        MinWidth="1080"
        MinHeight="740"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource TableBackgroundBrush}">
    <Grid x:Name="RootGrid" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="218" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.1*" />
            <ColumnDefinition Width="1.08*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Padding="18,14"
                Background="#D910231D"
                BorderBrush="#2B614F"
                BorderThickness="1"
                CornerRadius="8"
                Effect="{StaticResource PanelShadow}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="LanguageButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="LanguageButton_Click" />
                    <Button x:Name="NewHandButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="NewHandButton_Click" />
                    <Button x:Name="RushHandButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="RushHandButton_Click" />
                    <Button x:Name="HintButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="HintButton_Click" />
                    <Button x:Name="RushButton"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="RushButton_Click" />
                    <Button x:Name="PlayButton"
                            Style="{StaticResource CommandButtonStyle}"
                            Click="PlayButton_Click" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="30"
                               FontWeight="Bold" />
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock x:Name="TrumpText"
                                   Foreground="{StaticResource GoldBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,22,0" />
                        <TextBlock x:Name="ScoreText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="15"
                                   Margin="0,0,22,0" />
                        <TextBlock x:Name="RoleText"
                                   Foreground="{StaticResource AmberBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,22,0" />
                        <TextBlock x:Name="TurnText"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </WrapPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,14,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="178" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="178" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="116" />
                <RowDefinition Height="*" />
                <RowDefinition Height="112" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    x:Name="NorthSeat"
                    Margin="10,0"
                    Padding="14"
                    Background="#D910231D"
                    BorderBrush="#2B614F"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="NorthNameText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="NorthCountText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    x:Name="WestSeat"
                    Padding="14"
                    Background="#D910231D"
                    BorderBrush="#2B614F"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="WestNameText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="WestCountText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    x:Name="TableBorder"
                    Margin="12"
                    Padding="20"
                    Background="#D80B211A"
                    BorderBrush="#3A8468"
                    BorderThickness="1.4"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Ellipse Width="580"
                             Height="372"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Fill="#13342B"
                             Stroke="#3D866D"
                             StrokeThickness="2" />
                    <Ellipse Width="450"
                             Height="276"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Fill="#102A23"
                             Stroke="#255A4A"
                             StrokeThickness="1" />
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,18,0,0">
                        <TextBlock x:Name="PotTitleText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="CurrentPotText"
                                   Foreground="{StaticResource GoldBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                    <UniformGrid x:Name="CurrentTrickPanel"
                                 Rows="2"
                                 Columns="2"
                                 Width="560"
                                 Height="340"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                    <TextBlock x:Name="MessageText"
                               Foreground="{StaticResource GoldBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="2"
                    x:Name="EastSeat"
                    Padding="14"
                    Background="#D910231D"
                    BorderBrush="#2B614F"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="EastNameText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="EastCountText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.Column="1"
                    x:Name="SouthSeat"
                    Margin="10,0"
                    Padding="14"
                    Background="#D910231D"
                    BorderBrush="#2B614F"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="SouthNameText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="SouthCountText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1" Margin="0,14,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="14"
                    Background="#D910231D"
                    BorderBrush="#2B614F"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <StackPanel>
                    <TextBlock x:Name="ScorePanelTitleText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ScoreTeamText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,8,0,0" />
                    <ProgressBar x:Name="ScoreProgress"
                                 Height="12"
                                 Minimum="0"
                                 Maximum="80"
                                 Margin="0,12,0,0"
                                 Foreground="{StaticResource GoldBrush}"
                                 Background="#0B1A16" />
                    <TextBlock x:Name="RushStateText"
                               Foreground="{StaticResource AmberBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Padding="14"
                    Background="#D910231D"
                    BorderBrush="#2B614F"
                    BorderThickness="1"
                    CornerRadius="8"
                    Effect="{StaticResource PanelShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="LogTitleText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <ListBox x:Name="LogList"
                             Grid.Row="1"
                             Background="#9910221D"
                             BorderThickness="0"
                             Foreground="{StaticResource MutedTextBrush}"
                             FontSize="13"
                             Padding="8" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Padding="12"
                Background="#D910231D"
                BorderBrush="#2B614F"
                BorderThickness="1"
                CornerRadius="8"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Margin="4,0,4,8">
                    <TextBlock x:Name="HandTitleText"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectionText"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13"
                               HorizontalAlignment="Right"
                               DockPanel.Dock="Right" />
                </DockPanel>
                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="HumanHandPanel" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Canvas x:Name="AnimationCanvas"
                Grid.RowSpan="3"
                Grid.ColumnSpan="2"
                IsHitTestVisible="False"
                Panel.ZIndex="20" />

        <Border x:Name="ScoreFlash"
                Grid.RowSpan="3"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="260"
                Padding="28,18"
                Background="#E512231D"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Effect="{StaticResource PanelShadow}"
                Opacity="0"
                Visibility="Collapsed"
                Panel.ZIndex="30">
            <TextBlock x:Name="ScoreFlashText"
                       Foreground="{StaticResource GoldBrush}"
                       FontSize="30"
                       FontWeight="Bold"
                       TextAlignment="Center" />
        </Border>
    </Grid>
</Window>
